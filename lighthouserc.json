{
  "ci": {
    "collect": {
      "startServerCommand": "npx --yes serve -s .output/public -l 4173",
      "startServerReadyPattern": "Accepting connections|Local:",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/real-estate",
        "http://localhost:4173/construction",
        "http://localhost:4173/solar",
        "http://localhost:4173/medical",
        "http://localhost:4173/beauty",
        "http://localhost:4173/demo"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "image-alt": "error",
        "is-crawlable": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
